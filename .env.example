# Google Service Account 키 (base64 인코딩된 JSON)
# gcloud iam service-accounts keys create key.json --iam-account=YOUR_SA@PROJECT.iam.gserviceaccount.com
# base64 -i key.json | tr -d '\n' 으로 인코딩
GOOGLE_SERVICE_ACCOUNT_KEY=

# 경비 데이터를 저장할 Google Drive 폴더 ID
# 폴더 URL의 마지막 부분: https://drive.google.com/drive/folders/[이 부분]
GDRIVE_FOLDER_ID=

# 서버 포트 (기본: 8787, Vercel은 자동 설정)
PORT=8787
